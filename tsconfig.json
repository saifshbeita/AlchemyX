{
  "compilerOptions": {
    
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",

    /* Module Compilation & Resolutions */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,

    /* Paths & Project Bindings */
    "paths": {
      "@/*": [
        "./*"
      ]
    },

    /* Strict Mode and Flag Declarations */
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],

    /* Class Configurations & Decorators */
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  }
}
